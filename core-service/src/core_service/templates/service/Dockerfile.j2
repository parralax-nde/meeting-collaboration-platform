FROM python:3.11-slim

WORKDIR /app

# Install shared libraries first (layer caching).
# Build context must be the repository root (set in docker-compose.yml).
COPY shared-libs /tmp/mcp-shared
RUN pip install --no-cache-dir /tmp/mcp-shared

# Install service dependencies.
COPY {{ service_dir_name }}/requirements.txt ./
RUN pip install --no-cache-dir -r requirements.txt

# Copy application source.
COPY {{ service_dir_name }}/src/ ./src/

EXPOSE {{ port }}

CMD ["uvicorn", "src.{{ service_name }}.main:app", "--host", "0.0.0.0", "--port", "{{ port }}"]
